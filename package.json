{
  "name": "garantias-qa",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "test": "playwright test",
    "smoke": "playwright test --grep @smoke",
    "regression": "playwright test --grep @regression",
    "crud": "playwright test --grep @crud",
    "dashboard": "playwright test --grep @dashboard",
    "reportes": "playwright test --grep @reportes",
    "apiui": "playwright test --grep @apiui",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "history": "node scripts/generate-history.js",
    "qa:dashboard": "python -m http.server 8080",
    "qa:full": "npm run regression && npm run history",
    "performance:smoke": "k6 run performance/smoke-performance.test.js",
    "performance:load": "k6 run performance/load-tickets.test.js",
    "performance:stress": "k6 run performance/stress-tickets.test.js",
    "performance:create": "k6 run performance/create-ticket.test.js",
    "performance:search": "k6 run performance/create-and-search-ticket.test.js",
    "performance:crud": "k6 run performance/crud-ticket-flow.test.js" 
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1"
  }
}