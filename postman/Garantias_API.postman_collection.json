          ]
        }
      },
      "response": []
    },
    {
      "name": "Buscar Ticket",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();\r",
              "\r",
              "pm.test(\"Status 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Serie encontrada\", () => {\r",
              "\r",
              "    pm.expect(response.serie)\r",
              "        .to.eql(\r",
              "            pm.environment.get(\"ticketSerie\")\r",
              "        );\r",
              "\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/tickets/buscar?serie={{ticketSerie}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "tickets",
            "buscar"
          ],
          "query": [
            {
              "key": "serie",
              "value": "{{ticketSerie}}"
            }
          ]
        }
      },
      "response": []
    },
